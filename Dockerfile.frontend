# Build stage
FROM node:20-alpine AS builder

WORKDIR /app

# Copy package files
COPY web/package.json web/bun.lock ./
RUN npm install

# Copy source
COPY web/ ./

# Build
RUN npm run build

# Production stage
FROM nginx:alpine

# Copy built files
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy nginx config
COPY k8s/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
